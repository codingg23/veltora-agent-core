# Veltora Agent Core - environment variables
# Copy to .env and fill in values. Never commit .env.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Telemetry data path (directory containing Parquet files from synthetic-infra-datasets)
TELEMETRY_PATH=./data

# Redis (working memory)
REDIS_URL=redis://localhost:6379

# PostgreSQL + pgvector (episodic memory) - optional, system works without it
DATABASE_URL=postgresql://user:password@localhost:5432/veltora

# API server
VELTORA_API_KEY=your-api-key-here
ALLOWED_ORIGINS=http://localhost:3000,https://app.veltora.ai

# Monitoring loop
FACILITY_ID=SYDE-01
MONITOR_INTERVAL_S=60
